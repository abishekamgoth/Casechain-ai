# ============================================================
# .env.example
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub (it contains secret API keys!)
# .gitignore already excludes .env from git tracking.
#
# How to use:
#   cp .env.example .env
#   # Then edit .env with your actual keys
# ============================================================

# ---- LLM API Keys (choose at least one) ----
# Get Anthropic API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get OpenAI API key at: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Which LLM to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# ---- MLflow Configuration ----
# Where MLflow logs experiments
# Local: mlflow_runs (folder in your project)
# Remote: postgresql://user:pass@host:5432/db
MLFLOW_TRACKING_URI=mlflow_runs

# ---- Application Settings ----
# Number of similar cases to retrieve per query
TOP_K_RETRIEVAL=5

# Directory for FAISS index files
FAISS_INDEX_DIR=data/faiss_index

# ---- Development Settings ----
# Set to "true" in CI to use sample data (no real datasets needed)
CI=false
