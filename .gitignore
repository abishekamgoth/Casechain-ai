# ============================================================
# .gitignore — Files NOT to commit to GitHub
# ============================================================

# ---- CRITICAL: Never commit these ----
.env                          # Contains your secret API keys!
*.pem                         # SSH keys
*.key                         # Private keys

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
pip-wheel-metadata/

# ---- Data & Model Files (too large for GitHub) ----
data/echr_cases.json          # Download separately from Kaggle
data/scotus_cases.json
data/kanoon_cases.json
data/faiss_index/*.index      # Generated by build script
data/faiss_index/*.pkl
data/citation_graph.json      # Generated by build script

# ---- MLflow Runs (generated, not source code) ----
mlflow_runs/

# ---- Jupyter Notebooks ----
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ---- IDE Files ----
.idea/
.vscode/
*.swp
*.swo

# ---- OS Files ----
.DS_Store                     # Mac
Thumbs.db                     # Windows
desktop.ini

# ---- Testing ----
.pytest_cache/
.coverage
htmlcov/
test_results.txt
